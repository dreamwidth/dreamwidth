#!/usr/bin/perl
#
# importer-debug
#
# Diagnostic tool for debugging content-importer-verify connectivity issues.
# Run this on the ECS container to test each layer of the connection to a
# remote LJ-based site: DNS resolution, TCP connect, TLS handshake, HTTP,
# and XMLRPC protocol.
#
# Usage:
#   perl bin/dev/importer-debug <hostname>
#   perl bin/dev/importer-debug www.livejournal.com
#   perl bin/dev/importer-debug --userid=12345    # test using actual import_data
#
# Authors:
#      Mark Smith <mark@dreamwidth.org>
#
# Copyright (c) 2026 by Dreamwidth Studios, LLC.
#
