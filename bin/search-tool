#!/usr/bin/perl
#
# bin/search-tool
#
# Admin / backfill / test helper for the Manticore search system.
#
# Part of the Sphinx -> Manticore RT migration. Connects to Manticore
# on @LJ::MANTICORE via SphinxQL and reads from the live production
# cluster DBs (log2, logtext2, talk2, talktext2, supportlog). Safe to
# run against prod data — writes only go to Manticore.
#
# Subcommands:
#   import-user <username>                     synchronous recopy of one account
#                                              (always bypasses the 24h throttle)
#   import-all [--force]                       queue SearchCopier jobs for every
#                                              person/community journal;
#                                              --force bypasses the 24h throttle
#   import-support                             incremental supportlog -> dwsupport
#   search <query> [--journal U] [--global] [--table T]  run a query
#   show <journalid> <jitemid> <jtalkid>       dump one dw1 doc
#   show --table dwsupport <splid>             dump one dwsupport doc
#   delete <journalid> <jitemid> <jtalkid>     remove one dw1 doc
#   delete --table dwsupport <splid>           remove one dwsupport doc
#   count [--table dw1|dwsupport]              SELECT COUNT(*), both by default
#   flush                                      FLUSH RAMCHUNK on both tables
#
# Authors:
#      Mark Smith <mark@dreamwidth.org>
#
# Copyright (c) 2026 by Dreamwidth Studios, LLC.
#
# This program is free software; you may redistribute it and/or modify it under
# the same terms as Perl itself.  For a copy of the license, please reference
# 'perldoc perlartistic' or 'perldoc perlgpl'.
#

use strict;
use warnings;
use v5.10;

BEGIN {
    require "$ENV{LJHOME}/cgi-bin/ljlib.pl";
}

use DBI;
use Getopt::Long qw/:config pass_through/;

use DW::TaskQueue;
use DW::Task::SearchCopier;

my %DISPATCH = (
    'import-user'    => \&cmd_import_user,
    'import-all'     => \&cmd_import_all,
    'import-support' => \&cmd_import_support,
    'search'         => \&cmd_search,
    'show'           => \&cmd_show,
    'delete'         => \&cmd_delete,
    'count'          => \&cmd_count,
    'flush'          => \&cmd_flush,
);

sub usage {
    my $msg = shift;
    print STDERR "$msg\n\n" if $msg;
    print STDERR <<"EOF";
usage: $0 <command> [args]

commands:
  import-user <username>
  import-all [--force]
  import-support
  search <query> [--journal USER] [--global] [--table T]
  show <journalid> <jitemid> <jtalkid>   (or: --table dwsupport <splid>)
  delete <journalid> <jitemid> <jtalkid> (or: --table dwsupport <splid>)
  count [--table dw1|dwsupport]
  flush
EOF
    exit 1;
}

my $cmd = shift @ARGV or usage('missing command');
my $fn  = $DISPATCH{$cmd} or usage("unknown command: $cmd");
$fn->();
exit 0;

# -----------------------------------------------------------------------------
# Connection
# -----------------------------------------------------------------------------

sub manticore_dbh {
    die "\@LJ::MANTICORE is not configured\n" unless @LJ::MANTICORE;
    my ( $host, undef, $sql_port ) = @LJ::MANTICORE;
    return DBI->connect(
        "DBI:mysql:host=$host;port=$sql_port",
        undef, undef,
        {
            RaiseError        => 1,
            AutoCommit        => 1,
            PrintError        => 0,
            mysql_enable_utf8 => 1,
        },
    );
}

# -----------------------------------------------------------------------------
# Subcommand: import-user
#
# Runs DW::Task::SearchCopier synchronously (no queue dispatch). Same code
# path the worker uses, just called in-process — one implementation, two
# invocation modes. Forces through the 24h recopy throttle since the CLI
# is how we iterate during development.
# -----------------------------------------------------------------------------

sub cmd_import_user {
    my $username = shift @ARGV or usage('import-user: need <username>');

    my $u = LJ::load_user($username) or die "no such user: $username\n";
    printf "Importing %s (id=%d) synchronously...\n", $u->user, $u->id;

    # CLI invocation always bypasses the 24h throttle — the operator
    # explicitly asked for this import, so run it.
    my $task = DW::Task::SearchCopier->new( {
        userid => $u->id,
        source => 'search-tool',
        force  => 1,
    } );
    $task->work(undef);

    my $dbh = manticore_dbh();
    $dbh->do('FLUSH RAMCHUNK dw1');

    my ($total) = $dbh->selectrow_array(
        'SELECT COUNT(*) FROM dw1 WHERE journalid = ' . int( $u->id ) );
    printf "dw1 now has %d docs for journalid=%d\n", $total, $u->id;
    print "done\n";
}

# -----------------------------------------------------------------------------
# Subcommand: import-all
#
# Queue one SearchCopier job per person/community journal. Replaces
# bin/schedule-copier-jobs. 50ms sleep per dispatch to avoid hammering
# SQS (matches the old scheduler's cadence).
# -----------------------------------------------------------------------------

sub cmd_import_all {
    my $force;
    GetOptions( 'force' => \$force ) or usage();

    my $dbr = LJ::get_db_reader()
        or die "no db reader available\n";

    my $sth = $dbr->prepare(
        q{SELECT userid FROM user WHERE journaltype IN ('P','C')}
    );
    $sth->execute;

    printf "Queuing SearchCopier jobs for all P/C journals%s...\n",
        ( $force ? ' (force: will bypass 24h throttle)' : '' );

    my $n    = 0;
    my %args = ( source => 'import-all' );
    $args{force} = 1 if $force;
    while ( my ($userid) = $sth->fetchrow_array ) {
        DW::TaskQueue->dispatch(
            DW::Task::SearchCopier->new( { userid => $userid, %args } )
        );
        $n++;
        printf "  queued %d users so far...\n", $n if $n % 1000 == 0;
        select undef, undef, undef, 0.02;    # 50 ms throttle
    }
    printf "queued %d total\n", $n;
}

# -----------------------------------------------------------------------------
# Subcommand: search
# -----------------------------------------------------------------------------

sub cmd_search {
    my ( $journal_name, $global, $table );
    GetOptions(
        'journal=s' => \$journal_name,
        'global'    => \$global,
        'table=s'   => \$table,
    ) or usage();
    $table //= 'dw1';
    usage("search: unknown table '$table'")
        unless $table eq 'dw1' || $table eq 'dwsupport';

    my $query = shift @ARGV or usage('search: need <query>');

    my $dbh = manticore_dbh();

    # MATCH() takes a string — placeholder OK. Integer attrs must be
    # interpolated; Manticore's SphinxQL binds '?' as string.
    my @where = ('MATCH(?)');
    my @binds = ($query);

    if ( $table eq 'dw1' ) {
        push @where, 'is_deleted = 0';
        if ($journal_name) {
            my $u = LJ::load_user($journal_name)
                or die "no such user: $journal_name\n";
            push @where, 'journalid = ' . int $u->id;
        }
        push @where, 'allow_global_search = 1' if $global;

        my $sql = 'SELECT id, journalid, jitemid, jtalkid, poster_id, date_posted'
                . ' FROM dw1 WHERE ' . join( ' AND ', @where )
                . ' LIMIT 20 OPTION ranker=proximity_bm25';
        my $rows = $dbh->selectall_arrayref( $sql, { Slice => {} }, @binds );

        printf "found %d result(s)\n", scalar @$rows;
        for my $r (@$rows) {
            my $kind = $r->{jtalkid} ? 'comment' : 'entry';
            printf "  [%s] journal=%d jitemid=%d jtalkid=%d poster=%d date=%s\n",
                $kind, $r->{journalid}, $r->{jitemid}, $r->{jtalkid},
                $r->{poster_id},
                scalar localtime( $r->{date_posted} );
        }
    }
    else {   # dwsupport
        # dwsupport has no journalid/is_deleted/allow_global_search;
        # id == splid is the natural key.
        my $sql = 'SELECT id, spid, poster_id, faqid, touchtime'
                . ' FROM dwsupport WHERE ' . join( ' AND ', @where )
                . ' LIMIT 20 OPTION ranker=proximity_bm25';
        my $rows = $dbh->selectall_arrayref( $sql, { Slice => {} }, @binds );

        printf "found %d result(s)\n", scalar @$rows;
        for my $r (@$rows) {
            printf "  splid=%d spid=%d poster=%d faqid=%d touched=%s\n",
                $r->{id}, $r->{spid}, $r->{poster_id}, $r->{faqid},
                scalar localtime( $r->{touchtime} );
        }
    }
}

# -----------------------------------------------------------------------------
# Subcommand: import-support
#
# Incremental append of supportlog rows into dwsupport. Uses splid as the
# Manticore doc ID — splid is already unique + monotonic, so MAX(id) gives
# us the high-water mark in one query, and REPLACE makes re-runs idempotent.
# -----------------------------------------------------------------------------

sub cmd_import_support {
    my $dbh = manticore_dbh();
    my $dbr = LJ::get_db_reader()
        or die "no global db reader available\n";

    my ($last_imported) = $dbh->selectrow_array('SELECT MAX(id) FROM dwsupport');
    $last_imported //= 0;

    my ($max_splid) = $dbr->selectrow_array('SELECT MAX(splid) FROM supportlog');
    die "supportlog is empty\n" unless $max_splid;

    if ( $max_splid <= $last_imported ) {
        printf "up to date (last_imported=%d, supportlog_max=%d)\n",
            $last_imported, $max_splid;
        return;
    }

    printf "Importing splids %d..%d (%d row%s)\n",
        $last_imported + 1, $max_splid,
        $max_splid - $last_imported,
        ( $max_splid - $last_imported == 1 ? '' : 's' );

    # Batch 100 at a time, matching the old copy_supportlog cadence.
    my $i = $last_imported + 1;
    while ( $i <= $max_splid ) {
        my $j = $i + 99;
        $j = $max_splid if $j > $max_splid;

        my $rows = $dbr->selectall_arrayref(
            q{SELECT splid, spid, UNIX_TIMESTAMP(timelogged) AS touchtime,
                     faqid, userid, message
                FROM supportlog
                WHERE splid BETWEEN ? AND ?},
            { Slice => {} }, $i, $j,
        );

        for my $r (@$rows) {
            my $sql = sprintf(
                'REPLACE INTO dwsupport (id, spid, poster_id, faqid, touchtime, body)'
                . ' VALUES (%d, %d, %d, %d, %d, ?)',
                $r->{splid}, ( $r->{spid} // 0 ),
                ( $r->{userid} // 0 ),
                ( $r->{faqid} // 0 ),
                ( $r->{touchtime} // 0 ),
            );
            $dbh->do( $sql, {}, $r->{message} // '' );
        }

        printf "  splid %d..%d done\n", $i, $j;
        $i = $j + 1;
    }

    $dbh->do('FLUSH RAMCHUNK dwsupport');
    print "done\n";
}

# -----------------------------------------------------------------------------
# Subcommand: show
# -----------------------------------------------------------------------------

sub cmd_show {
    my $table;
    GetOptions( 'table=s' => \$table ) or usage();
    $table //= 'dw1';
    usage("show: unknown table '$table'")
        unless $table eq 'dw1' || $table eq 'dwsupport';

    my $dbh = manticore_dbh();
    my ( $sql, @display_keys );

    if ( $table eq 'dw1' ) {
        my ( $jid, $jitemid, $jtalkid ) = @ARGV;
        usage('show: need <journalid> <jitemid> <jtalkid>')
            unless defined $jid && defined $jitemid && defined $jtalkid;

        $sql = sprintf(
            'SELECT id, journalid, jitemid, jtalkid, poster_id, date_posted,'
            . ' allow_global_search, is_deleted, security_bits, title, body'
            . ' FROM dw1 WHERE journalid=%d AND jitemid=%d AND jtalkid=%d',
            int $jid, int $jitemid, int $jtalkid,
        );
        @display_keys = qw/ id journalid jitemid jtalkid poster_id date_posted
                            allow_global_search is_deleted security_bits title /;
    }
    else {   # dwsupport — splid IS the doc id
        my ($splid) = @ARGV;
        usage('show --table dwsupport: need <splid>') unless defined $splid;

        $sql = sprintf(
            'SELECT id, spid, poster_id, faqid, touchtime, body'
            . ' FROM dwsupport WHERE id=%d',
            int $splid,
        );
        @display_keys = qw/ id spid poster_id faqid touchtime /;
    }

    my $rows = $dbh->selectall_arrayref( $sql, { Slice => {} } );
    unless (@$rows) {
        print "no match\n";
        return;
    }

    for my $r (@$rows) {
        printf "%-20s %s\n", $_, ( $r->{$_} // '' ) for @display_keys;
        my $body = $r->{body} // '';
        if ( length $body > 500 ) {
            printf "%-20s %s ... [%d chars truncated]\n",
                'body', substr( $body, 0, 500 ), length($body) - 500;
        }
        else {
            printf "%-20s %s\n", 'body', $body;
        }
        print "\n";
    }
}

# -----------------------------------------------------------------------------
# Subcommand: delete
# -----------------------------------------------------------------------------

sub cmd_delete {
    my $table;
    GetOptions( 'table=s' => \$table ) or usage();
    $table //= 'dw1';
    usage("delete: unknown table '$table'")
        unless $table eq 'dw1' || $table eq 'dwsupport';

    my $dbh = manticore_dbh();
    my $sql;

    if ( $table eq 'dw1' ) {
        my ( $jid, $jitemid, $jtalkid ) = @ARGV;
        usage('delete: need <journalid> <jitemid> <jtalkid>')
            unless defined $jid && defined $jitemid && defined $jtalkid;
        $sql = sprintf(
            'DELETE FROM dw1 WHERE journalid=%d AND jitemid=%d AND jtalkid=%d',
            int $jid, int $jitemid, int $jtalkid,
        );
    }
    else {   # dwsupport
        my ($splid) = @ARGV;
        usage('delete --table dwsupport: need <splid>') unless defined $splid;
        $sql = sprintf( 'DELETE FROM dwsupport WHERE id=%d', int $splid );
    }

    my $n = $dbh->do($sql);

    # DBI returns "0E0" for zero rows on success; coerce to a real count.
    $n = ( $n && $n ne '0E0' ) ? $n : 0;
    printf "deleted %d row(s)\n", $n;
}

# -----------------------------------------------------------------------------
# Subcommand: count
# -----------------------------------------------------------------------------

sub cmd_count {
    my $only;
    GetOptions( 'table=s' => \$only ) or usage();

    my $dbh    = manticore_dbh();
    my @tables = $only ? ($only) : qw/ dw1 dwsupport /;

    for my $t (@tables) {
        my ($n) = $dbh->selectrow_array("SELECT COUNT(*) FROM $t");
        printf "%-10s %d\n", $t, $n;
    }
}

# -----------------------------------------------------------------------------
# Subcommand: flush
# -----------------------------------------------------------------------------

sub cmd_flush {
    my $dbh = manticore_dbh();
    for my $t (qw/ dw1 dwsupport /) {
        $dbh->do("FLUSH RAMCHUNK $t");
        print "flushed $t\n";
    }
}
