{
    "containerDefinitions": [
        {
            "name": "web",
            "image": "ghcr.io/dreamwidth/web:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 6081,
                    "hostPort": 6081,
                    "protocol": "tcp"
                },
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "command": [
                "bash",
                "/opt/startup-prod.sh"
            ],
            "environment": [],
            "mountPoints": [
                {
                    "sourceVolume": "dw-config",
                    "containerPath": "/dw/etc",
                    "readOnly": true
                }
            ],
            "volumesFrom": [],
            "linuxParameters": {
                "initProcessEnabled": true
            },
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-create-group": "true",
                    "awslogs-group": "/dreamwidth/web/shop",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "shop"
                }
            }
        }
    ],
    "family": "web-shop",
    "taskRoleArn": "arn:aws:iam::194396987458:role/dreamwidth-ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::194396987458:role/dreamwidth-ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [
        {
            "name": "dw-config",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-f9f3e04d",
                "rootDirectory": "/etc-stable",
                "transitEncryption": "DISABLED"
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "6144"
}
